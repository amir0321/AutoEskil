# ============================================
# BACKEND MILJÖVARIABLER FÖR RENDER.COM
# ============================================

# Port (Render sätter denna automatiskt)
# PORT=3001

# Database URL (från Render PostgreSQL)
# DATABASE_URL=postgresql://user:password@hostname:5432/database

# Tillåtna origins för CORS (kommaseparerad lista)
# ALLOWED_ORIGINS=https://autoeskil.se,https://www.autoeskil.se

# Din webbplats URL (för SEO/sitemap)
# PUBLIC_SITE_URL=https://autoeskil.se

# JWT Secret för autentisering
# JWT_SECRET=your-secret-key-here

# Cloudinary (för bilduppladdning)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# INSTRUKTIONER FÖR RENDER.COM
# ============================================
#
# 1. Skapa dessa miljövariabler i Render dashboard:
#    - DATABASE_URL (från PostgreSQL-databasen)
#    - JWT_SECRET (generera en lång slumpmässig sträng)
#    - Andra variabler enligt ditt behov
#
# 2. Build Command i Render:
#    npm install && npm run build
#
# 3. Start Command i Render:
#    npm start
#
# ============================================

