{
  "name": "autoeskil",
  "version": "1.0.0",
  "description": "Full-stack car marketplace application",
  "private": true,
  "type": "module",
  "scripts": {
    "install-all": "npm install && npm --prefix packages/Frontend install && npm --prefix packages/Backend install",
    "dev": "sh -c 'npm --prefix packages/Backend start & npm --prefix packages/Frontend run dev; wait'",
    "backend:start": "npm --prefix packages/Backend start",
    "backend:test": "npm --prefix packages/Backend test",
    "frontend:dev": "npm --prefix packages/Frontend run dev",
    "frontend:build": "npm --prefix packages/Frontend run build",
    "frontend:lint": "npm --prefix packages/Frontend run lint",
    "frontend:preview": "npm --prefix packages/Frontend run preview",
    "build": "npm --prefix packages/Frontend run build",
    "start": "node packages/Backend/server.js"
  }
}
